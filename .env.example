# Dashboard config
# CLOUD_ENABLED=true shows the Claude Code Remote (cloud) pane. Requires the
# Claude Code CLI to be logged in (`claude login`) so the dashboard can read
# the OAuth token from the macOS Keychain. Leave unset or "false" for a
# launchd-only dashboard.
CLOUD_ENABLED=false

# Hosts allowed to skip TLS verification on outbound n8n webhook POSTs.
# Only touches those exact hostnames; every other request still validates.
# Use ONLY for your own n8n instance with a mismatched cert (e.g. Hostinger's
# `n8n.srvXXXX.hstgr.cloud`, where the wildcard SAN covers only the VPS root
# domain, not the n8n subdomain). Comma-separated.
# Example:
# N8N_INSECURE_HOSTS=n8n.srv1092493.hstgr.cloud
N8N_INSECURE_HOSTS=
